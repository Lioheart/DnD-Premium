        "Shape-Shift": {
            "name": "Shape-Shift",
            "description": {
                "value": "<p class=\"feature\">[[lookup @name]] shape-shifts into a Large wolf-humanoid hybrid form or a Medium wolf, or it returns to its true humanoid form, or he returns to its true form. Its game statistics, other than its size, are the same in each form. Any equipment it is wearing or carrying isn’t transformed.</p><section class=\"secret\" id=\"secret-D36xZfDfJHOK8pdJ\"><p><strong>Foundry Note</strong></p><p>Use when Frantosh uses the Harkon’s Bite necklace he wears to transform into a Werewolf.</p></section>"
            }

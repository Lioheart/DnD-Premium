        "Axe Beak": {
            "name": "Toporodziób",
            "description": "<blockquote><p>Don’t let the grouchy reputation of these hardworking creatures deter you. A team of axe beaks can pull your sled with remarkable speed and efficiency.</p></blockquote><p><em>(see the @UUID[Compendium.dnd-monster-manual.content.JournalEntry.mmAppendixMonste.JournalEntryPage.HbA0tUgLR0NxiPyW]{Monster Manual})</em></p>",
            "alignment": "Bez charakteru",
            "items": {

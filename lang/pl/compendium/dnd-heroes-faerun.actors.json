        "Domestic Wonder": {
            "name": "Domestic Wonder",
            "description": "<p>This bipedal wonder is designed to assist with household duties. It vaguely resembles whatever species its creator used as inspiration. An activated domestic wonder uses the Domestic Wonder stat block.</p><p>The wonder is an ally to you and your allies. In combat, the wonder shares your Initiative count, but it takes its turn immediately after yours. It obeys your verbal commands (no action required by you). If you don’t issue any, it takes the Dodge action and uses its movement to avoid danger.</p><p>The domestic wonder is destroyed if it drops to 0 Hit Points.</p>",
            "alignment": "Bez charakteru",
            "items": {
                "Mechanical Determination": {
                    "name": "Mechanical Determination",
                    "description": "<p>If damage reduces the wonder to 0 Hit Points, it makes a Constitution saving throw with a DC of 5 plus the damage taken unless the damage is Lightning or from a Critical Hit. On a successful save, the wonder drops to 1 Hit Point instead.</p>",
                    "activities": {
                        "save": {
                            "damageOnSave": "none"
                        }
                    }
                },
                "Wind-Up Operation": {
                    "name": "Wind-Up Operation",
                    "description": "<p>The wonder has the &amp;Reference[Unconscious apply=false] condition until another creature winds it with the wonder’s unique key for 1 minute. Once wound, the wonder operates for 10 days or until a creature touches the wonder with its key as a Utilize action to deactivate it, after which the wonder has the &amp;Reference[Unconscious apply=false] condition until it is wound again.</p><section id=\"secret-giTfe8tQdtxMe0In\" class=\"secret\"><p><strong>Foundry Note</strong></p><p>The wonder begins in the Unconscious state. To place the wonder in its Wound Up state, disable the <strong>Active Effect (AE)</strong> located on the <strong>Effects Tab</strong> of the character sheet.</p></section>",
                    "activities": {
                        "Wind-Up": {
                            "name": "Wind-Up"
                        }
                    },
                    "effects": {
                        "Unconscious": {
                            "name": "Nieprzytomny",
                            "description": "<p>The wonder is &amp;Reference[unconscious apply=false]{unconscious} until it is wound again.</p>"
                        }
                    }
                }
            }
        },
        "Flying Snake": {
            "name": "Wąż latający",
            "description": "<blockquote><p>Our partners in the Zhentarim provide these remarkable pets, fully domesticated and trained to deliver messages. Always wear gloves when handling venomous creatures.</p></blockquote><p><em>(see the @UUID[Compendium.dnd-monster-manual.content.JournalEntry.mmAppendixAAnima.JournalEntryPage.IO3FQv6plccdlyiN]{Monster Manual})</em></p>",
            "alignment": "Bez charakteru",
            "items": {
                "Flyby": {
                    "name": "Przelot",
                    "description": "<p>[[lookup @name]] nie prowokuje &amp;Reference[OpportunityAttacks]{Ataków okazyjnych}, gdy wylatuje poza zasięg wroga.</p>",
                    "requirements": "Wylatuje poza zasięg wroga"
                },
                "Bite": {
                    "name": "Ugryzienie",
                    "description": "<p>[[/attack extended]]. [[/damage average extended]].</p>"
                }
            }
        },
        "Sled Dog": {
            "name": "Sled Dog",
            "description": "<blockquote><p>We recommend a team of these sled dogs to ease the burden on individual animals. Rotate your dogs through the lead positions to give weary animals a rest.</p></blockquote><p>A sled dog pulling a sled alone must take a &amp;Reference[Short Rest] after pulling a sled for 1 hour; otherwise, it gains 1 &amp;Reference[Exhaustion] level.</p><p><em>(see the @UUID[Compendium.dnd-monster-manual.content.JournalEntry.mmAppendixAAnima.JournalEntryPage.Ls3RwFhjHWdrOSAK]{Monster Manual})</em></p>",
            "alignment": "Bez charakteru",
            "items": {
                "Pack Tactics": {
                    "name": "Atak grupowy",
                    "description": "<p>[[lookup @name]] ma Ułatwienie w teście ataku przeciwko istocie, jeśli co najmniej jeden sojusznik potwora [[lookup @name lowercase]] znajduje się w odległości 5 stóp od tej istoty i nie ma stanu Obezwładniony.</p>",
                    "requirements": "Sojusznik w odległości 5 stóp od celu ataku"
                },
                "Bite": {
                    "name": "Ugryzienie",
                    "description": "<p>[[/attack extended]]. [[/damage average extended]]. Jeśli cel jest Średnią lub mniejszą istotą, otrzymuje stan &amp;Reference[Prone apply=false].</p>",
                    "effects": {
                        "Prone": {
                            "name": "Powalony",
                            "description": "<p>Jeśli cel jest Średnią lub mniejszą istotą, otrzymuje stan &amp;Reference[Prone apply=false].</p>"
                        }
                    }
                }
            }
        }
